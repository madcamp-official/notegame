# Server
HOST=127.0.0.1
PORT=8787
NODE_ENV=development
LOG_LEVEL=info

# "memory" starts with no external services. Use "postgres" for durable runs.
STORAGE=memory
DATABASE_URL=postgresql://keyboard_wanderer:change-me@127.0.0.1:5432/keyboard_wanderer
DATABASE_SSL=false

# Cross-process request lease. Keep the lease shorter than the wait timeout;
# active requests renew it automatically while model work is in progress.
IDEMPOTENCY_LEASE_MS=30000
IDEMPOTENCY_WAIT_TIMEOUT_MS=25000

# Local mode supplies DEFAULT_USER_ID when x-user-id is omitted.
# Set AUTH_MODE=required behind an identity-aware gateway in production.
AUTH_MODE=local
DEFAULT_USER_ID=00000000-0000-4000-8000-000000000001

# Development-only run diagnostics and /public test tools. Enabled only when
# NODE_ENV=development; every other environment ignores this flag.
ENABLE_DEBUG_ROUTES=false

# Optional. When absent or unavailable, narration uses a deterministic fallback.
# Never expose this value to Unity or commit a populated .env file.
GEMINI_API_KEY=
GEMINI_TIMEOUT_MS=15000
GEMINI_CIRCUIT_COOLDOWN_MS=30000
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_QUALITY_MODEL=gemini-3.1-flash-lite
GEMINI_FAST_OUTPUT_TOKENS=1024
GEMINI_QUALITY_OUTPUT_TOKENS=1536

# Which LLM backs the director/narrator: "gemini" (default) or "vllm" (a local
# OpenAI-compatible vLLM server, e.g. Qwen served as "game-director").
LLM_PROVIDER=gemini
LLM_TURN_DEADLINE_MS=60000
LLM_TURN_MAX_CALLS=6
LLM_MAX_CONCURRENT_REQUESTS=2

# vLLM (used only when LLM_PROVIDER=vllm). Point VLLM_BASE_URL at the OpenAI-
# compatible /v1 root — through an SSH tunnel this is typically the local
# forwarded port. The key is sent as a Bearer token; never expose it to Unity.
# When VLLM_BASE_URL is empty, the director uses the deterministic fallback.
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=
VLLM_MODEL=game-director
VLLM_TIMEOUT_MS=20000
VLLM_CIRCUIT_COOLDOWN_MS=30000
VLLM_FAST_OUTPUT_TOKENS=1024
VLLM_QUALITY_OUTPUT_TOKENS=1024

# Leave empty for the built-in localhost/127.0.0.1 development list. A non-empty
# comma-separated value replaces that list, so include every required origin.
CORS_ORIGINS=
# Response traces are written below Server/ and are gitignored. Disable them in
# production unless a protected, short-lived diagnostic capture is required.
LLM_RESPONSE_TRACE=true
LLM_RESPONSE_TRACE_FILE=logs/llm-responses.jsonl
