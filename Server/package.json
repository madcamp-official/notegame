{
  "name": "narrative-game-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Server for the narrative game project",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "check": "node scripts/static-check.mjs",
    "test": "node --test --test-reporter=spec",
    "world:generate": "node scripts/generate-world.js",
    "world:validate": "node scripts/generate-world.js --count 32 --summary-only"
  },
  "dependencies": {
    "pg": "^8.13.1"
  }
}
